{
  "name": "hikvision-sync-agent",
  "version": "1.0.1",
  "description": "Meedo Hikvision attendance synchronization tray application",
  "productName": "Meedo Hikvision Sync Agent",
  "private": true,
  "main": "dist/electron-main.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:digest": "npm run build && node scripts/test-digest.mjs",
    "test:renderer": "npm run build && node scripts/test-renderer.mjs",
    "test:schedule": "npm run build && node scripts/test-schedule.mjs",
    "test:logger": "npm run build && node scripts/test-logger.mjs",
    "start": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis --x64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/xml2js": "^0.4.14",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.geoplan.meedo.hikvision-sync-agent",
    "productName": "Meedo Hikvision Sync Agent",
    "artifactName": "Meedo-Hikvision-Sync-Agent-Setup-${version}.${ext}",
    "asar": true,
    "files": [
      "dist/**/*",
      "preload.cjs",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "installer.nsh"
    }
  }
}
